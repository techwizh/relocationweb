# Vercel frontend only — your Render backend URL (no trailing slash)
API_URL="https://relocationweb-api.onrender.com"

# PostgreSQL (Render backend only — do not set on Vercel)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Vercel Blob (auto-set when you add Blob storage on Vercel; optional locally)
BLOB_READ_WRITE_TOKEN=""

# M-Pesa Daraja API (keep sandbox until Safaricom Go Live)
SKIP_MPESA_PAYMENT="false"
MPESA_ENV="sandbox"
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_SHORTCODE="174379"
MPESA_PASSKEY=""
# Must be your live site URL, e.g. https://relocate.vercel.app/api/mpesa/callback
MPESA_CALLBACK_URL="https://your-domain.vercel.app/api/mpesa/callback"
MPESA_ACCOUNT_REFERENCE="Relocate"
MPESA_TRANSACTION_DESC="Move booking"

# Map provider (optional)
NEXT_PUBLIC_MAPBOX_TOKEN=""

# Admin login — change these before going public
ADMIN_USERNAME="techwiz"
ADMIN_PASSWORD="change-this-strong-password"
ADMIN_SESSION_SECRET="change-this-to-a-long-random-string-at-least-32-chars"

# Techwiz Company contact (public — shown on About & Contact pages)
NEXT_PUBLIC_COMPANY_NAME="Techwiz Company"
NEXT_PUBLIC_COMPANY_TAGLINE="Building reliable digital platforms for Kenya."
NEXT_PUBLIC_CONTACT_LINKEDIN="https://www.linkedin.com/in/victor-kioko"
NEXT_PUBLIC_CONTACT_INSTAGRAM="https://www.instagram.com/techwizcompany"
NEXT_PUBLIC_CONTACT_WHATSAPP=""
NEXT_PUBLIC_CONTACT_EMAIL="info@techwiz.co.ke"
NEXT_PUBLIC_CONTACT_PHONE="+254712345678"
